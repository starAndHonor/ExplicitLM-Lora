# Explicit-LoRA 环境变量模板
# 将此文件复制为 .env 并填入实际值
# 注意：.env 文件已加入 .gitignore，不会提交到版本库

# ─────────────────────────────────────────────
# 模型路径（绝对路径，覆盖 config/default.yaml 中的相对路径）
# ─────────────────────────────────────────────

# 基础模型权重目录（覆盖 paths.model_dir）
MODEL_PATH=/absolute/path/to/qwen3-0.6B

# LLMLingua 压缩模型目录（覆盖 paths.llmlingua_model_dir）
LLMLINGUA_PATH=/absolute/path/to/llmlingua-2-xlm-roberta-large

# ─────────────────────────────────────────────
# API Token（下载受限模型或使用外部服务）
# ─────────────────────────────────────────────

# Hugging Face Token（下载 gated 模型时需要）
HF_TOKEN=your_hf_token_here

# ─────────────────────────────────────────────
# GPU 设置
# ─────────────────────────────────────────────

# 训练/评测使用的 GPU 编号（逗号分隔）
# 注意：训练脚本通过 CUDA_VISIBLE_DEVICES 控制，不硬编码设备
CUDA_VISIBLE_DEVICES=0,1
